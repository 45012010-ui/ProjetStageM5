# Base PostgreSQL du module M1
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/consultation_db

# Modèle HuggingFace utilisé pour générer les embeddings
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Dimension des embeddings générés par le modèle
EMBEDDING_DIM=384
